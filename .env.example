# ---- Server (API) ----
PORT=3001
DATABASE_URL=postgresql://postgres.<ref>:<password>@<host>.pooler.supabase.com:6543/postgres

# Master key for encrypting users' bring-your-own provider API keys (AES-256-GCM).
# Must decode to exactly 32 bytes: 64 hex chars, or base64 of 32 bytes.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-hex-chars>

# Supabase project URL — used to verify access tokens against the project JWKS.
SUPABASE_URL=https://<ref>.supabase.co

# ---- Client (Vite) ----
# These are also read from client/.env in local dev.
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>
# Base URL of the deployed API (leave empty in dev — the Vite proxy handles /api).
VITE_API_URL=
